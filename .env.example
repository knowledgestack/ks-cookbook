# Copy to .env and fill in:  cp .env.example .env

# Your KS API key. Issue one from the dashboard, or for local dev:
#   curl -X POST http://localhost:28000/v1/api-keys -b "ks_uat=..." -d '{"name":"cookbook"}'
KS_API_KEY=sk-user-...

# KS API base URL. Default is the prod SaaS; override for local:
KS_BASE_URL=https://api.knowledgestack.ai

# LLM for the demo agents. Only ONE of these is required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
